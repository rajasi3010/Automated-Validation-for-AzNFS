# Copy this file to .env and fill in the values for local development.
# .env is in .gitignore and must NEVER be committed.
#
# In production (self-hosted runner on vmscan) these come from
# GitHub Actions Secrets and Variables, not from this file.

# ----------------------------------------------------------
# Azure — required for both local dev and GitHub Actions
# ----------------------------------------------------------

# Subscription that hosts the VM, ACS resource, and any Marketplace queries.
AZURE_SUBSCRIPTION_ID=

# User-assigned Managed Identity client-ID (the one attached to vmscan).
# Leave blank only if you are using a system-assigned MI or `az login` locally.
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# ----------------------------------------------------------
# ACS Email — used by scripts/notifier.py
# These values are non-secret identifiers — safe to commit if you wish.
# ----------------------------------------------------------

# ACS resource Email endpoint (Overview blade > Endpoint).
# Example: https://acscomm.india.communication.azure.com
ACS_ENDPOINT=

# MailFrom address from the ECS subdomain linked to the ACS resource.
# Example: DoNotReply@<guid>.azurecomm.net
ACS_SENDER=

# Optional override. Defaults to the recipient list baked into scripts/config.py.
# NOTIFY_RECIPIENTS=a@example.com,b@example.com

# ----------------------------------------------------------
# Optional path overrides (rarely needed)
# ----------------------------------------------------------

# Where to store the SQLite database (default: project root)
DB_PATH=

# Where to write the JSON output (default: output/)
OUTPUT_DIR=
