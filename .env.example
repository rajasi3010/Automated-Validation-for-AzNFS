# Copy this file to .env and fill in the values.
# .env is in .gitignore and must NEVER be committed.

# ----------------------------------------------------------
# Azure — required for both local dev and GitHub Actions
# ----------------------------------------------------------

# Your Azure subscription ID
AZURE_SUBSCRIPTION_ID=

# Service principal credentials (used in GitHub Actions and CI)
# For local dev, run `az login` instead — leave these blank.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ----------------------------------------------------------
# Optional path overrides
# ----------------------------------------------------------

# Where to store the SQLite database (default: project root)
DB_PATH=

# Where to write the JSON output (default: output/)
OUTPUT_DIR=
